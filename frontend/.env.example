# Base URL of the FastAPI backend (specs/01-auth-rbac-tower-setup/backend.md).
# The typed fetch client (lib/api/client.ts) calls `${NEXT_PUBLIC_API_BASE_URL}/api/v1/...`
# with `credentials: 'include'` so the backend's httpOnly access/refresh token
# cookies are sent on every request.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
