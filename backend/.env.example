# Copy this file to `.env` and adjust for your environment.
# See ../docker-compose.yml for the local-dev Postgres service this DATABASE_URL points at.

ENV=local
DEBUG=true

# postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# Matches the `postgres` service in the root docker-compose.yml (db/user/password: aavaas).
DATABASE_URL=postgresql+asyncpg://aavaas:aavaas@localhost:5432/aavaas

# HS256 signing secret for access tokens. In AWS, this is pulled from Secrets Manager at
# aavaas/{env}/jwt-signing-key (see specs/01-auth-rbac-tower-setup/cloud.md) — locally, any
# long random string works.
JWT_SIGNING_KEY=change-me-to-a-long-random-string-in-every-real-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie behavior — set COOKIE_SECURE=true behind HTTPS (staging/prod).
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
